# SmartTransport — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_transport
DB_USER=postgres
DB_PASSWORD=your_password_here

# CV pipeline defaults (can be overridden via CLI flags)
BUS_ID=1
# STATION_ID is optional — defaults to 3 (Bab Saadoun) for color mode,
# 4 (Ariana Centre) for bw mode. Override with --station-id flag.
